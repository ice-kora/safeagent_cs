# SafeAgent-CS Demo Profile — 本地 PostgreSQL + Milvus + bge-m3 配置
# ======================================================
# 使用方法：
#   1. 复制本文件为 .env.local
#   2. 启动 PostgreSQL 和 Milvus 容器（见下方说明）
#   3. 执行 python scripts/seed_demo_postgres.py --reset 初始化 demo 数据
#   4. 执行 python scripts/ingest_knowledge_to_milvus.py --reset 导入知识库
#   5. 启动 uvicorn
#   6. 打开 http://127.0.0.1:8010/console/
#
# Docker PostgreSQL 快速启动：
#   docker run --name safeagent-pg \
#     -e POSTGRES_USER=safeagent \
#     -e POSTGRES_PASSWORD=safeagent_pwd \
#     -e POSTGRES_DB=safeagent_cs \
#     -p 5432:5432 \
#     -d postgres:16
#
# 安全提醒：
#   本文件是公开模板，不包含真实密码或 API key。
#   真实密钥请放在 .env.local（已通过 .gitignore 排除），不要提交到仓库。

# Profile: demo（PG + workflow + langgraph）
SAFEAGENT_PROFILE=demo

# PostgreSQL 连接（platform data + runtime store 共用）
DATABASE_URL=postgresql://safeagent:safeagent_pwd@localhost:5432/safeagent_cs
SAFEAGENT_RUNTIME_DATABASE_URL=postgresql://safeagent:safeagent_pwd@localhost:5432/safeagent_cs

# Workflow 引擎
SAFEAGENT_WORKFLOW_MODE=workflow
SAFEAGENT_WORKFLOW_ENGINE=langgraph

# LLM 模式（demo 默认 rule；要启用真实 LLM 请在 .env.local 中覆盖）
SAFEAGENT_LLM_MODE=rule

# 工具后端（demo 默认 mock；生产环境改为 external_stub）
SAFEAGENT_TOOL_BACKEND=mock

# RAG：demo 主线使用真实 Milvus + BAAI/bge-m3。
# 普通 dev / pytest 可以继续使用 memory + mock embedding。
SAFEAGENT_RAG_VECTOR_STORE=milvus
SAFEAGENT_RAG_MILVUS_URI=http://localhost:19530
SAFEAGENT_RAG_COLLECTION=safeagent_knowledge

SAFEAGENT_RAG_EMBEDDING_PROVIDER=bge_m3
SAFEAGENT_RAG_EMBEDDING_MODEL=BAAI/bge-m3
SAFEAGENT_RAG_EMBEDDING_DEVICE=cpu
SAFEAGENT_RAG_MODEL_CACHE_DIR=.cache/huggingface

SAFEAGENT_RAG_HYBRID_ENABLED=true
SAFEAGENT_RAG_DENSE_WEIGHT=0.7
SAFEAGENT_RAG_KEYWORD_WEIGHT=0.3
SAFEAGENT_RAG_TOP_K=5
