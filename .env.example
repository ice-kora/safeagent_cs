# SafeAgent-CS runtime profile
# ==============================
# 通用配置说明。如需本地 PostgreSQL Demo，请复制 .env.demo.example 为 .env.local。
#
# dev  = SQLite + manual/rule + mock tools
# demo = PostgreSQL + workflow/langgraph + Milvus+bge-m3 RAG + mock tools
# prod = PostgreSQL + workflow/langgraph + guarded real LLM + controlled external tools
SAFEAGENT_PROFILE=dev

# Profile overrides. Leave unset to use the selected profile defaults.
# SAFEAGENT_WORKFLOW_MODE=manual
# SAFEAGENT_WORKFLOW_ENGINE=style
# SAFEAGENT_LLM_MODE=rule
# SAFEAGENT_TOOL_BACKEND=mock

# Platform Data backend.
# dev default: sqlite
# demo/prod default: postgres
# SAFEAGENT_DB_BACKEND=sqlite
# DATABASE_URL=postgresql://safeagent:safeagent@localhost:5432/safeagent

# Runtime Store backend.
# dev default: sqlite
# demo/prod default: postgres
# SAFEAGENT_RUNTIME_BACKEND=sqlite
# SAFEAGENT_RUNTIME_DATABASE_URL=postgresql://safeagent:safeagent@localhost:5432/safeagent_runtime

# Optional OpenAI-compatible LLM provider.
# SAFEAGENT_LLM_MODE=real_llm
# SAFEAGENT_LLM_PROVIDER=openai_compatible
# SAFEAGENT_LLM_BASE_URL=https://api.example.com/v1
# SAFEAGENT_LLM_MODEL=example-chat-model
# SAFEAGENT_LLM_TIMEOUT_SECONDS=30
# SAFEAGENT_LLM_API_KEY=replace-with-local-secret

# RAG / Milvus / embeddings.
# Tests and dev default to memory + mock embedding; demo defaults to Milvus + bge_m3.
# SAFEAGENT_RAG_VECTOR_STORE=memory
# SAFEAGENT_RAG_MILVUS_URI=http://localhost:19530
# SAFEAGENT_RAG_COLLECTION=safeagent_knowledge
# SAFEAGENT_RAG_TOP_K=5
# SAFEAGENT_RAG_HYBRID_ENABLED=true
# SAFEAGENT_RAG_DENSE_WEIGHT=0.7
# SAFEAGENT_RAG_KEYWORD_WEIGHT=0.3
# SAFEAGENT_RAG_EMBEDDING_PROVIDER=mock
# SAFEAGENT_RAG_EMBEDDING_MODEL=BAAI/bge-m3
# SAFEAGENT_RAG_EMBEDDING_DEVICE=cpu
# SAFEAGENT_RAG_MODEL_CACHE_DIR=.cache/huggingface
# SAFEAGENT_RAG_ALLOW_DENSE_ONLY=false

# Optional MCP mock adapter. Disabled by default so the default tool registry
# and allowlist stay limited to the four core mock tools.
# SAFEAGENT_MCP_MOCK_ENABLED=false

# Demo profile example:
# SAFEAGENT_PROFILE=demo
# DATABASE_URL=postgresql://safeagent:safeagent@localhost:5432/safeagent
# SAFEAGENT_RUNTIME_DATABASE_URL=postgresql://safeagent:safeagent@localhost:5432/safeagent_runtime
# SAFEAGENT_LLM_MODE=rule
# SAFEAGENT_RAG_VECTOR_STORE=milvus
# SAFEAGENT_RAG_MILVUS_URI=http://localhost:19530
# SAFEAGENT_RAG_EMBEDDING_PROVIDER=bge_m3

# Prod profile example:
# SAFEAGENT_PROFILE=prod
# DATABASE_URL=postgresql://safeagent:safeagent@postgres:5432/safeagent
# SAFEAGENT_RUNTIME_DATABASE_URL=postgresql://safeagent:safeagent@postgres:5432/safeagent_runtime
# SAFEAGENT_LLM_MODE=real_llm
# SAFEAGENT_TOOL_BACKEND=external_stub
